# ---- LLM (any OpenAI-compatible endpoint) ----
OPENAI_API_KEY=sk-your-key-here
# Default is OpenAI. Point this at Ollama / LM Studio / Groq / Together / a proxy, etc.
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# ---- Search ----
# Location passed to LinkedIn's job search (e.g. Taiwan / Remote / London / United States)
JOB_LOCATION=Taiwan

# ---- Optional ----
# If set, a "translate" button appears on each full JD (e.g. "Traditional Chinese").
TRANSLATE_JD_TO=
PORT=8080
